# ─── AI API Keys ───
MERCURY_API_KEY=your_mercury_api_key_here           # Used for ALL AI features (summaries, quizzes, PPT, metadata extraction, chat)
# GEMINI_API_KEY=your_api_key_here                  # No longer used — kept for backwards compatibility

# ─── Supabase (Database + Auth) ───
SUPABASE_URL=https://your-project.supabase.co       # Your Supabase project URL
SUPABASE_SERVICE_KEY=your_service_role_key_here     # Supabase service_role key (for backend admin operations)

# ─── Authentication ───
# Supabase Auth handles JWT tokens automatically.
# The frontend uses the anon key (NEXT_PUBLIC_SUPABASE_ANON_KEY) for client-side auth.

# ─── Admin Credentials ───
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123

# ─── CORS ───
# For local development: http://localhost:3000
# For production: https://your-vercel-app.vercel.app
CORS_ORIGINS=http://localhost:3000

# ─── File Uploads ───
# For local development: ./uploads
# For Render (production): /tmp/uploads (ephemeral storage)
UPLOAD_DIR=./uploads