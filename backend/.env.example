# ─── AI API Keys ───
MERCURY_API_KEY=your_mercury_api_key_here           # Used for ALL AI features (summaries, quizzes, PPT, metadata extraction, chat)
# GEMINI_API_KEY=your_api_key_here                  # No longer used — kept for backwards compatibility

# ─── Database ───
# Use mongodb://localhost:27017 for local development
# Use mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/ for MongoDB Atlas (production)
MONGO_URI=mongodb://localhost:27017
MONGO_DATABASE=research_summarizer

# ─── Authentication ───
SECRET_KEY=a_strong_random_string_at_least_32_chars_long

# ─── Admin Credentials ───
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123

# ─── CORS ───
# For local development: http://localhost:3000
# For production: https://your-vercel-app.vercel.app
CORS_ORIGINS=http://localhost:3000

# ─── File Uploads ───
# For local development: ./uploads
# For Render (production): /tmp/uploads (ephemeral storage)
UPLOAD_DIR=./uploads
